# Database
DATABASE_URL=postgresql+asyncpg://richson_user:password@localhost:5432/richman

# Internal service auth (shared secret with richman)
INTERNAL_API_KEY=change-me-in-production

# Platform LLM key (used for scheduled asset-level analysis)
PLATFORM_LLM_API_KEY=sk-...

# FRED API (macroeconomic data)
FRED_API_KEY=...

# Server
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info
WORKERS=1

# LLM provider defaults
DEFAULT_LLM_PROVIDER=claude
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Budget guard
DAILY_LLM_BUDGET_USD=10.0

# CORS (comma-separated origins, empty = deny all)
CORS_ALLOWED_ORIGINS=http://localhost:3000
