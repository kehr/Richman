# Database — dev default targets local docker postgres (docker-compose.yml).
# For prod, point to your managed database and use asyncpg driver.
DATABASE_URL=postgresql+asyncpg://richman:richman@localhost:5433/richman

# Internal service auth (shared secret with richman)
INTERNAL_API_KEY=change-me-in-production

# Platform LLM key (used for scheduled asset-level analysis)
PLATFORM_LLM_API_KEY=sk-...

# FRED API (macroeconomic data)
FRED_API_KEY=...

# Server
# APP_ENV selects the log renderer: "dev" uses colored ConsoleRenderer;
# any other value (test/staging/prod) uses JSONRenderer for structured logs.
APP_ENV=dev
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info
WORKERS=1

# LLM provider defaults
DEFAULT_LLM_PROVIDER=claude
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Budget guard
DAILY_LLM_BUDGET_USD=10.0

# CORS (comma-separated origins, empty = deny all)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Alembic migration config path (relative to /app in container)
ALEMBIC_CONFIG_PATH=alembic.ini

# Richman backend base URL (for internal callbacks)
RICHMAN_BASE_URL=http://richman:8080
