# Database — dev default targets local docker postgres (docker-compose.yml).
# For prod, point to your managed database and use asyncpg driver.
DATABASE_URL=postgresql+asyncpg://richman:richman@localhost:5433/richman

# Internal service auth (shared secret with richman)
INTERNAL_API_KEY=change-me-in-production

# Platform LLM key (used for scheduled asset-level analysis)
PLATFORM_LLM_API_KEY=sk-...

# FRED API (macroeconomic data). Register a key at
# https://fred.stlouisfed.org/docs/api/api_key.html — it must be a 32-character
# lowercase alphanumeric string. Leave empty to disable FRED fetches; any value
# that is not shaped like a real key will also be treated as "disabled" so the
# scheduler does not flood logs with Bad Request retries.
FRED_API_KEY=

# Server
# APP_ENV selects the log renderer: "dev" uses colored ConsoleRenderer;
# any other value (test/staging/prod) uses JSONRenderer for structured logs.
APP_ENV=dev
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info
WORKERS=1

# LLM provider defaults
DEFAULT_LLM_PROVIDER=claude
DEFAULT_LLM_MODEL=claude-sonnet-4-20250514

# Budget guard
DAILY_LLM_BUDGET_USD=10.0

# CORS (comma-separated origins, empty = deny all)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Proxy bypass whitelist for direct-to-China data sources. Dev machines
# typically set HTTP_PROXY / HTTPS_PROXY for FRED / Yahoo / Polymarket access;
# akshare talks to push2his.eastmoney.com which must stay off the proxy or
# transient proxy failures surface as 502 on /market/ohlcv/<a-share-code>.
# Leave empty to use the default list baked into richson.main.
NO_PROXY=.eastmoney.com,push2his.eastmoney.com,push2.eastmoney.com,127.0.0.1,localhost

# Alembic migration config path (relative to /app in container)
ALEMBIC_CONFIG_PATH=alembic.ini

# Richman backend base URL (for internal callbacks)
RICHMAN_BASE_URL=http://richman:8080
