# App environment: dev | prod
APP_ENV=dev
# HTTP server port
SERVER_PORT=8080
# PostgreSQL connection
DATABASE_URL=postgres://richman:richman@localhost:5433/richman?sslmode=disable
# JWT secret for auth
JWT_SECRET=change-me-in-production
# LLM provider: claude | openai
LLM_PROVIDER=claude
# Claude API key
CLAUDE_API_KEY=
# OpenAI API key
OPENAI_API_KEY=
# LLM vision provider: claude (MVP only supports claude)
LLM_VISION_PROVIDER=claude
# Vision API key; falls back to CLAUDE_API_KEY when empty and provider=claude
VISION_API_KEY=
# Optional override for vision API endpoint (default: https://api.anthropic.com/v1/messages)
VISION_API_ENDPOINT=
# Optional override for vision model id (default: claude-sonnet-4-20250514)
VISION_MODEL=
# Vision request timeout in seconds (default: 30)
LLM_VISION_TIMEOUT_SECONDS=30
# Master key used to AES-256-GCM encrypt per-user LLM API keys stored in the
# llm_configs table. Must be exactly 64 hex characters (32 raw bytes). Generate
# a fresh value with: openssl rand -hex 32. The server refuses to start if this
# is missing or malformed. Rotating this key invalidates all stored api keys.
LLM_CONFIG_MASTER_KEY=
# Timeout applied to every LLM provider connectivity probe and to each
# Resolver call against a user-configured provider. Format: Go duration
# (e.g. 3s, 5s, 10s). Default is 5s to keep a degraded provider from stalling
# the synthesis pipeline.
LLM_PROBE_TIMEOUT=5s
# Market data sources
AKSHARE_BASE_URL=http://localhost:8808
# Analysis task controls
ANALYSIS_TASK_TTL_HOURS=24
ANALYSIS_TIMEOUT_SECONDS=45
ANALYSIS_MAX_CONCURRENT=4
# WeChat official account
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# Feishu bot webhook
FEISHU_WEBHOOK_URL=
# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Logging
LOG_LEVEL=info
LOG_DIR=/var/log/richman
# richson sidecar
RICHSON_BASE_URL=http://localhost:8100
RICHSON_API_KEY=
# Platform LLM (for batch analysis and weekly insight jobs)
PLATFORM_LLM_PROVIDER=claude
PLATFORM_LLM_API_KEY=
PLATFORM_LLM_MODEL=claude-sonnet-4-20250514
PLATFORM_LLM_API_BASE=
# CORS allowed origins (comma-separated, used in non-dev mode)
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Public-facing app base URL (used in email unsubscribe links)
APP_BASE_URL=https://richman.app
# SMTP From address for outbound emails
SMTP_FROM=Richman <noreply@richman.app>
