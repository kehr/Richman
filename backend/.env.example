# App environment: dev | prod
APP_ENV=dev
# HTTP server port
SERVER_PORT=8080
# PostgreSQL connection
DATABASE_URL=postgres://richman:richman@localhost:5433/richman?sslmode=disable
# JWT secret for auth
JWT_SECRET=change-me-in-production
# LLM provider: claude | openai
LLM_PROVIDER=claude
# Claude API key
CLAUDE_API_KEY=
# OpenAI API key
OPENAI_API_KEY=
# WeChat official account
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# Feishu bot webhook
FEISHU_WEBHOOK_URL=
# SMTP email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Logging
LOG_LEVEL=info
LOG_DIR=/var/log/richman
