# API base URL (host only, no path).
# The /api/v1 or /api/v2 prefix is appended by src/domain/http/client.ts,
# so VITE_API_BASE must NOT include any path segment.
# Dev: leave empty (VITE_API_BASE=) so the browser uses a relative path
# and the Vite dev proxy forwards /api/* to the backend on localhost.
# Prod: absolute origin of the deployed backend, e.g. https://api.example.com
VITE_API_BASE=
# App environment: dev | prod
VITE_APP_ENV=dev
