# API base URL for backend.
# Dev: use a relative path like /api/v1 — the Vite dev proxy in
# vite.config.ts forwards /api/* to the backend on localhost, so the
# frontend works over any hostname (localhost / LAN IP / mapped domain)
# without reconfiguration per consumer machine.
# Prod: use an absolute URL pointing at the deployed backend.
VITE_API_BASE=/api/v1
# App environment: dev | prod
VITE_APP_ENV=dev
