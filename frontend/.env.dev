# API base URL (host only, no path).
# Dev: leave empty so the browser uses a relative path; the Vite dev proxy
# in vite.config.ts forwards /api/* to http://localhost:8080 on the machine
# running `pnpm dev`. Works over any hostname (localhost / LAN IP / mapped
# domain) without per-consumer reconfiguration.
# The /api/v1 or /api/v2 prefix is appended by src/domain/http/client.ts.
VITE_API_BASE=
# App environment: dev | prod
VITE_APP_ENV=dev
