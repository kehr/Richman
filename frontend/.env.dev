# API base URL for backend.
# In dev we use a relative path so the browser always talks to whichever
# host it opened the Vite dev server on (localhost, a LAN IP, or a mapped
# hostname). The Vite dev proxy in vite.config.ts forwards /api/* to
# http://localhost:8080 on the machine running `pnpm dev`, so cross-machine
# access works without hardcoding a specific hostname per consumer.
VITE_API_BASE=/api/v1
# App environment: dev | prod
VITE_APP_ENV=dev
