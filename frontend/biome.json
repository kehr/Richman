{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"nursery": {
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"paths": {
							"antd": "Import from '@/ui-kit/eat' instead of 'antd' directly.",
							"@ant-design/pro-components": "Import from '@/ui-kit/eat' instead of '@ant-design/pro-components' directly.",
							"@ant-design/icons": "Import from '@/ui-kit/eat' instead of '@ant-design/icons' directly.",
							"@ant-design/charts": "Import from '@/ui-kit' instead of '@ant-design/charts' directly."
						}
					}
				}
			}
		}
	},
	"overrides": [
		{
			"include": ["src/ui-kit/**"],
			"linter": {
				"rules": {
					"nursery": {
						"noRestrictedImports": "off"
					}
				}
			}
		}
	]
}
